<?xml version="1.0"?>
<robot name="puma" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Robot based on https://grabcad.com/library/robot-puma-560 -->
  <!-- FIXED to follow the IK from modern robotics textbook -->
  <!-- INFO Wrist joints 4, 5, and 6 are YXY different from ZYX from the book -->
  
  <!-- a1 0.623 -->
  <!-- d1 0.14 -->
  <!-- a2 0.45 -->
  <!-- a3 0.49 -->
  <!-- a4 0.05 wrist to end-effector not used here -->

  <link name="map">
        <visual>
      <geometry>
        <mesh filename="package://puma_description/meshes/base.stl" scale="1 1 1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="map_to_s" type="fixed">
    <parent link="map"/>
    <child link="{s}"/>
    <origin xyz="0 0 0.623" rpy="0 0 0"/>   <!-- a1 0.623 -->
  </joint>

  <link name="{s}">
  </link>
  
  <joint name="joint1" type="revolute">
    <parent link="{s}"/>
    <child link="{1}"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" velocity="2.0" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="{1}">
    <visual>
      <geometry>
        <mesh filename="package://puma_description/meshes/link1.stl" scale="1 1 1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="{1}"/>
    <child link="{2}"/>
    <origin xyz="0.14 0 0" rpy="0 1.57 0"/> <!-- d1 0.14 -->
    <axis xyz="0 0 1"/>
    <limit effort="100.0" velocity="2.0" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="{2}">
    <visual>
      <geometry>
        <mesh filename="package://puma_description/meshes/link2.stl" scale="1 1 1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="{2}"/>
    <child link="{3}"/>
    <origin xyz="0 0.45 0" rpy="0 0 0"/> <!-- a2 0.45 -->
    <axis xyz="0 0 1"/>
    <limit effort="100.0" velocity="2.0" lower="-3.14" upper="3.14"/>
  </joint>
   
  <link name="{3}">
    <visual>
      <geometry>
        <mesh filename="package://puma_description/meshes/link3.stl" scale="1 1 1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="{3}"/>
    <child link="{4}"/>
    <origin xyz="0 0.49 0" rpy="-1.57 0 0"/> <!-- a3 0.49 -->
    <axis xyz="0 0 1"/>
    <limit effort="100.0" velocity="2.0" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="{4}">
    <visual>
      <geometry>
        <mesh filename="package://puma_description/meshes/link4.stl" scale="1 1 1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="{4}"/>
    <child link="{5}"/>
    <origin xyz="0 0 0" rpy="1.57 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" velocity="2.0" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="{5}">
    <visual>
      <geometry>
        <mesh filename="package://puma_description/meshes/link5.stl" scale="1 1 1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint6" type="revolute">
    <parent link="{5}"/>
    <child link="{6}"/>
    <origin xyz="0 0 0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" velocity="2.0" lower="-3.14" upper="3.14"/>
  </joint> 

  <link name="{6}"/>
  
  <joint name="jointb" type="fixed">
    <parent link="{6}"/>
    <child link="{b}"/>
    <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
    <axis xyz="0 0 1"/>
  </joint> 
  
  <link name="{b}"/>
</robot>
